# Environment variable template for GodWorld QR Store
# Copy this file to .env and fill in your own values.
# NEVER commit a .env file containing real secrets.

# ── Ethereum node ────────────────────────────────────────────────────────────
# Get a free endpoint from Infura (https://infura.io) or Alchemy (https://alchemy.com)
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_PROJECT_ID

# Alternative: Polygon Mumbai testnet
MUMBAI_RPC_URL=https://polygon-mumbai.infura.io/v3/YOUR_PROJECT_ID

# ── Wallet ───────────────────────────────────────────────────────────────────
# The private key of the deployer / backend wallet (0x-prefixed).
# Use a dedicated test wallet — never use a wallet holding mainnet funds.
PRIVATE_KEY=0xYOUR_PRIVATE_KEY

# ── Deployed contract ────────────────────────────────────────────────────────
# Populated automatically by scripts/deploy.js; can also be set manually.
QRSTORE_ADDRESS=

# ── Block explorer verification ──────────────────────────────────────────────
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_API_KEY
POLYGONSCAN_API_KEY=YOUR_POLYGONSCAN_API_KEY

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/godworld
