# ──────────────────────────────────────────────
#  Blue-Star — Environment Variables
# ──────────────────────────────────────────────

# Server
PORT=3000
NODE_ENV=development

# Anthropic / Claude AI
ANTHROPIC_API_KEY=your_anthropic_api_key_here
CLAUDE_MODEL=claude-3-5-sonnet-20241022

# Blockchain / Smart Contracts
# RPC endpoint for the target EVM network (e.g. Ethereum, Polygon, local Hardhat)
BLOCKCHAIN_RPC_URL=http://127.0.0.1:8545
# Private key of the deployer wallet (never commit a real key)
DEPLOYER_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE
# Pre-deployed contract addresses (populated after first deploy)
QR_STORE_CONTRACT_ADDRESS=
CREDIT_SYSTEM_CONTRACT_ADDRESS=
GLS_LOGISTICS_CONTRACT_ADDRESS=

# QR Store
QR_STORE_BASE_URL=https://qrstore.example.com

# GLS / Logistics
GLS_WEBHOOK_SECRET=your_webhook_secret_here
